# ── Option A: Azure AI Foundry (recommended) ─────────────────
# Find these in your Foundry project → Settings → Keys and Endpoint
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com/models
AZURE_AI_FOUNDRY_KEY=<your-api-key>
AZURE_AI_FOUNDRY_DEPLOYMENT=gpt-4o

# ── Option B: Azure OpenAI (classic) ─────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Option C: OpenAI ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
